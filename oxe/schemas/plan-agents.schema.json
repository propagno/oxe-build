{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oxe-cc.local/schemas/plan-agents.schema.json",
  "title": "OXE plan-agents blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": ["oxePlanAgentsSchema", "goal", "agents", "execution"],
  "properties": {
    "oxePlanAgentsSchema": {
      "type": "integer",
      "enum": [2, 3],
      "description": "Schema 3 = atual (com model_hint). Schema 2 = aceito (sem model_hint). Schema 1 = legado (não recomendado)."
    },
    "goal": { "type": "string", "minLength": 1 },
    "specRef": { "type": "string" },
    "runId": {
      "type": "string",
      "minLength": 8,
      "description": "Obrigatório quando oxePlanAgentsSchema >= 2"
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "since"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending_execute", "executing", "closed", "invalidated"]
        },
        "since": { "type": "string", "minLength": 1 },
        "invalidatedReason": { "type": "string" },
        "invalidatedBy": {
          "type": "string",
          "enum": ["quick", "out_of_scope", "new_plan", "manual"]
        }
      },
      "description": "Obrigatório quando oxePlanAgentsSchema >= 2"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "scope", "taskIds"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "role": { "type": "string", "minLength": 1 },
          "persona": {
            "type": "string",
            "minLength": 1,
            "description": "ID de persona em oxe/personas/ (ex.: executor, architect). Opcional."
          },
          "scope": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "taskIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^T[1-9][0-9]*$"
            },
            "minItems": 1
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "model_hint": {
            "type": "string",
            "enum": ["fast", "balanced", "powerful"],
            "description": "Tier de modelo sugerido para este agente (schema v3). Opcional."
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "waves"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["sequential", "parallel_per_wave", "hybrid"]
        },
        "waves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "oxePlanAgentsSchema": { "enum": [2, 3] } },
        "required": ["oxePlanAgentsSchema"]
      },
      "then": {
        "required": ["oxePlanAgentsSchema", "goal", "agents", "execution", "runId", "lifecycle"]
      }
    }
  ]
}
